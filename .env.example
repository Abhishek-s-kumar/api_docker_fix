# ==============================================================
# WRD API v2.0.0 — Environment Configuration Template
# Copy this file to .env and fill in all values
# ==============================================================

# ── Application ─────────────────────────────────────────────
ENVIRONMENT=development          # development | staging | production
APP_NAME="Wazuh Rules Distribution API"
APP_VERSION=2.0.0
DEBUG=false
LOG_LEVEL=INFO                   # DEBUG | INFO | WARNING | ERROR

# ── API Server ───────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
WORKERS=4                        # Gunicorn worker count (prod)
RELOAD=false                     # Enable hot-reload (dev only)

# ── Database (PostgreSQL) ────────────────────────────────────
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_NAME=wazuh_api
DATABASE_USER=api
DATABASE_PASSWORD=changeme_strong_password   # Override via Docker Secret in prod
DATABASE_URL=postgresql+asyncpg://api:changeme_strong_password@postgres:5432/wazuh_api
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
REDIS_CACHE_TTL=300              # seconds
REDIS_PUBSUB_CHANNEL=wrd:sync:events

# ── Security ─────────────────────────────────────────────────
SECRET_KEY=changeme_generate_with_openssl_rand_hex_32
JWT_SECRET=changeme_generate_with_openssl_rand_hex_32
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
ADMIN_KEY_FILE=/data/admin_key.txt

# ── Secrets (Docker Secrets file paths, override in prod) ───
SECRET_KEY_FILE=/run/secrets/secret_key
JWT_SECRET_FILE=/run/secrets/jwt_secret
DB_PASSWORD_FILE=/run/secrets/db_password

# ── Celery ───────────────────────────────────────────────────
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
CELERY_TASK_SERIALIZER=json
CELERY_RESULT_EXPIRES=3600

# ── Git Repository ───────────────────────────────────────────
GIT_REPO_PATH=/app/git-repo
GIT_REMOTE_URL=https://github.com/Abhishek-s-kumar/wazuh-api-docker.git
GIT_BRANCH=main
GIT_SYNC_INTERVAL=300            # seconds between auto-sync
GIT_VERIFY_SIGNATURES=false      # Enable GPG signature verification

# ── Rule Packages ────────────────────────────────────────────
RULES_BASE_PATH=/app/git-repo
RULES_PACKAGE_DIR=/tmp/rule-packages
MAX_PACKAGE_SIZE_MB=50

# ── CORS ─────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000","http://localhost:8080"]
CORS_ALLOW_CREDENTIALS=true

# ── Rate Limiting ────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_BURST=20
